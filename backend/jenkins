pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Test Docker') {
            steps {
                sh 'docker version'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t interiorvision-backend ./backend'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f interiorvision-backend || true'
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker run -d --name interiorvision-backend \
                -p 3000:3000 \
                interiorvision-backend
                '''
            }
        }
    }

    post {
        success {
            echo '🚀 Deployment SUCCESS'
        }
        failure {
            echo '❌ Deployment FAILED'
        }
    }
}